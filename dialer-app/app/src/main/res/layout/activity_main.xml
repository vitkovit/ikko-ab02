<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <FrameLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom tab bar: Recent · Contacts · Dial -->
    <LinearLayout
        android:id="@+id/tab_bar"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:orientation="horizontal"
        android:background="#0a0a0a">

        <LinearLayout
            android:id="@+id/tab_recents"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/tab_recents_icon"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_recents"
                    android:tint="#444444" />
                <View
                    android:id="@+id/tab_recents_dot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-1dp"
                    android:layout_marginEnd="-2dp"
                    android:background="@drawable/dot_missed"
                    android:visibility="gone" />
            </FrameLayout>
            <TextView
                android:id="@+id/tab_recents_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent"
                android:textColor="#444444"
                android:textSize="19sp"
                android:layout_marginTop="5dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_contacts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/tab_contacts_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_contacts"
                android:tint="#ffffff" />
            <TextView
                android:id="@+id/tab_contacts_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contacts"
                android:textColor="#ffffff"
                android:textSize="19sp"
                android:layout_marginTop="5dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_dial"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/tab_dial_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_dial"
                android:tint="#444444" />
            <TextView
                android:id="@+id/tab_dial_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dial"
                android:textColor="#444444"
                android:textSize="19sp"
                android:layout_marginTop="5dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
