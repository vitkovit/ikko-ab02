<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:clipChildren="false"
    android:paddingTop="18dp">

    <!-- Search + Import -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="SEARCH"
            android:textColorHint="#282828"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:letterSpacing="0.12"
            android:singleLine="true"
            android:inputType="textPersonName" />

        <TextView
            android:id="@+id/btn_import"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:text="IMPORT"
            android:textColor="#333333"
            android:textSize="11sp"
            android:letterSpacing="0.1" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#111111" />

    <!-- clipChildren=false so slider letters can bloom OVER the list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ListView
            android:id="@+id/list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingEnd="22dp"
            android:clipToPadding="false"
            android:divider="@null"
            android:scrollbarSize="0dp" />

        <!-- AlphaSlider is FULL WIDTH so ballooning letters have room to draw over the list -->
        <com.mw.dialer.AlphaSlider
            android:id="@+id/alpha_slider"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="16dp"
            android:paddingBottom="16dp" />

    </FrameLayout>

</LinearLayout>
