<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:paddingTop="8dp"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center"
        android:textColor="#ffffff"
        android:textSize="42sp"
        android:fontFamily="@font/ndot57"
        android:letterSpacing="0.05"
        android:hint="—"
        android:textColorHint="#222222"
        android:singleLine="true" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <TextView android:id="@+id/key1" style="@style/Key" android:text="1" />
        <TextView android:id="@+id/key2" style="@style/Key" android:text="2" />
        <TextView android:id="@+id/key3" style="@style/Key" android:text="3" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <TextView android:id="@+id/key4" style="@style/Key" android:text="4" />
        <TextView android:id="@+id/key5" style="@style/Key" android:text="5" />
        <TextView android:id="@+id/key6" style="@style/Key" android:text="6" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <TextView android:id="@+id/key7" style="@style/Key" android:text="7" />
        <TextView android:id="@+id/key8" style="@style/Key" android:text="8" />
        <TextView android:id="@+id/key9" style="@style/Key" android:text="9" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <TextView android:id="@+id/keyStar" style="@style/Key" android:text="*" />
        <TextView android:id="@+id/key0" style="@style/Key" android:text="0" />
        <TextView android:id="@+id/keyHash" style="@style/Key" android:text="#" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.1" android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:id="@+id/keyDel"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_margin="3dp" android:gravity="center"
            android:text="&#x232B;" android:textSize="24sp" android:textColor="#888888" />
        <TextView android:id="@+id/keyCall"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2"
            android:layout_margin="3dp" android:gravity="center"
            android:text="CALL" android:textSize="18sp" android:letterSpacing="0.15"
            android:textColor="#ffffff" android:background="@drawable/call_bg" />
    </LinearLayout>

</LinearLayout>
