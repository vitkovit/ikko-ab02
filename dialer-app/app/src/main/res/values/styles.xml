<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorPrimary">#000000</item>
        <item name="android:colorPrimaryDark">#000000</item>
        <item name="android:colorAccent">#ffffff</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:textColorPrimary">#ffffff</item>
        <item name="android:textColorSecondary">#666666</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <!-- dotted "Ndot" font to match the Focus / dotted-clock theme -->
        <item name="android:fontFamily">@font/ndot57</item>
    </style>

    <style name="Key">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">3dp</item>
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:layout_marginBottom">3dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#ffffff</item>
        <item name="android:textSize">44sp</item>
        <item name="android:fontFamily">@font/ndot57</item>
        <item name="android:background">@drawable/key_bg</item>
    </style>
</resources>
